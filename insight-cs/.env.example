# Insight CS · 环境变量示例
# 复制本文件为 .env 并填入真实 key
# cp .env.example .env

# ─────────────────────────────────────────────
# LLM Provider(任选其一,启动时按优先级自动检测)
# 详见 LLM_PROVIDER_SETUP.md
# ─────────────────────────────────────────────

# 1) DeepSeek(推荐 · 最高性价比)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) 阿里通义千问 Qwen(电商场景词汇最强)
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3) 字节豆包 Doubao(高吞吐 · 批量便宜)
# ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4) Anthropic Claude(沙箱默认 · 质量最佳)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 可选:强制指定 provider(覆盖自动检测)
# ─────────────────────────────────────────────
# LLM_PROVIDER=deepseek         # deepseek | qwen | doubao | platform
# LLM_FAST_MODEL=deepseek-chat  # 快速场景模型
# LLM_QUALITY_MODEL=deepseek-chat # 深度分析模型

# ─────────────────────────────────────────────
# 运行环境
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
